PORT=3000

# AI provider — Gemini only (contract asks for two; re-add a fallback for prod)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Shared secret the Android app must send as X-App-Key
APP_API_KEY=change-me-to-a-long-random-string

# Google Sign-In (F1) — the *Web* OAuth client ID from Google Cloud Console.
# Must match GOOGLE_WEB_CLIENT_ID in the Android app's build.gradle.kts.
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Dev-only fallback: allow X-App-Key auth (never set true in production)
ALLOW_APP_KEY=true   # dev mode — set false before production

# Dev mode: skip all auth. MUST be removed/false in production.
AUTH_DISABLED=true

# Session signing secret — 32+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Apple Sign In — your iOS bundle id (audience of Apple's identity token)
APPLE_BUNDLE_ID=com.yourorg.myassistant

# Where the SQLite user DB lives (mount a Docker volume here)
DATA_DIR=./data

# Groq — fastest inference, generous free tier. Get a key at console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Which providers to try, in order (missing keys are skipped)
AI_PROVIDER_ORDER=groq,gemini
